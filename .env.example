EVENT_DATABASE_URL=postgresql+psycopg://event:event_dev_password@localhost:5432/security_events
EVENT_TEST_DATABASE_URL=postgresql+psycopg://event_test:event_test_password@localhost:5433/security_events_test
EVENT_API_HOST=127.0.0.1
EVENT_API_PORT=8001
EVENT_SQL_ECHO=false

# NL2SQL 需要 OpenAI-compatible Chat Completions 接口。
# 例如 OpenAI: https://api.openai.com/v1
# 例如本地 Ollama OpenAI 兼容接口: http://127.0.0.1:11434/v1
LLM_BASE_URL=
LLM_API_KEY=
LLM_MODEL=

# RAG 知识库 Embedding 需要 OpenAI-compatible /embeddings 接口。
# 可以与 LLM 使用同一个服务，也可以指向单独的本地 embedding 服务。
EMBEDDING_BASE_URL=
EMBEDDING_API_KEY=
EMBEDDING_MODEL=
RAG_TOP_K=5
RAG_CHUNK_SIZE=800
RAG_CHUNK_OVERLAP=120
# 开发演示默认开启：未配置 Embedding/LLM 时使用本地简化向量和摘要回答。
# 正式环境建议设为 false，并配置上面的模型服务。
RAG_LOCAL_DEMO_MODE=true
